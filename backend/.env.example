# Database Configuration
# SQLite (default): sqlite:///./distillery.db
# PostgreSQL: postgresql://user:password@localhost/distillery
DATABASE_URL=sqlite:///./distillery.db

# JWT Configuration
# IMPORTANT: Change this to a secure random string in production!
JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345

# HuggingFace Integration (optional)
HUGGINGFACE_API_KEY=your-huggingface-api-key-here
HUGGINGFACE_API_URL=https://api-inference.huggingface.co

# CORS Configuration
# Allow these origins to call the API. Comma-separated list.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Server Configuration (when running with uvicorn)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

